# AI provider: "gemini" (default) or "kimi"
AI_PROVIDER=gemini

# Google AI Studio — required when AI_PROVIDER=gemini
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Moonshot (Kimi) — required when AI_PROVIDER=kimi
# Get one at: https://platform.moonshot.ai/
MOONSHOT_API_KEY=

# SQLite DB URL (aiosqlite driver)
DB_URL=sqlite+aiosqlite:///.data/ai.db

# Allowed CORS origins (comma-separated or JSON list)
# Default: http://localhost:3000 (the web app)
# CORS_ORIGINS=["http://localhost:3000"]

LOG_LEVEL=INFO
